# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Resend
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_WEBHOOK_SECRET=whsec_xxxxx  # From Resend dashboard > Webhooks

# Webhooks
WEBHOOK_SECRET=your-webhook-signing-secret

# Enrichment - ZeroBounce (email validation)
ZEROBOUNCE_API_KEY=your-zerobounce-api-key

# Enrichment - MaxMind GeoIP2 (IP geolocation)
MAXMIND_ACCOUNT_ID=your-maxmind-account-id
MAXMIND_LICENSE_KEY=your-maxmind-license-key

# Enrichment - Experian ConsumerView (credit data, NO credit pull)
EXPERIAN_CLIENT_ID=your-experian-client-id
EXPERIAN_CLIENT_SECRET=your-experian-client-secret
EXPERIAN_USERNAME=your-experian-username
EXPERIAN_PASSWORD=your-experian-password
EXPERIAN_SUBCODE=your-experian-subcode

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Security
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# Retell AI (Voice Calling)
RETELL_API_KEY=key_xxxxx
RETELL_WEBHOOK_SECRET=whsec_xxxxx
RETELL_AGENT_ID=                  # Default Retell agent (used for inbound + outbound if no override)
RETELL_OUTBOUND_AGENT_ID=         # Optional override for outbound reactivation calls (Day 10 of Reactivation campaign)

# ── Marketing Connectors ──────────────────────

# Google Ads — Offline Conversions (push CRM events back to Google Ads)
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
# Per-org: customer_id, refresh_token, conversion_actions stored in connector_configs table

# Meta Conversions API (server-side events to Facebook/Instagram)
META_PIXEL_ID=your-pixel-id
META_CAPI_ACCESS_TOKEN=your-access-token
# Per-org: pixel_id + access_token stored in connector_configs table

# GA4 Measurement Protocol (server-side events to Google Analytics 4)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your-api-secret

# Slack Notifications (Incoming Webhook for team alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# Outbound Webhooks (Zapier/Make.com — per-org, stored in connector_configs)
# No env vars needed — configured per organization in the dashboard

# ── Cron / scheduled jobs ──
CRON_SECRET=your-vercel-cron-secret  # Bearer token Vercel cron passes; required by /api/cron/* routes

# ── Phase 1: Cal.com (per-org settings live in connector_configs) ──
# Cal.com API key + webhook_secret are stored per-org in connector_configs.credentials.
# Settings stored per-org in connector_configs.settings:
#   booking_base_url   — e.g. https://cal.com/dion-health
#   event_types[]      — { slug, cal_event_type_id, label, duration_minutes }
# No global env vars required.

# ── Phase 2: Meta CAPI test mode ──
META_CAPI_TEST_EVENT_CODE=  # optional: validate events in Events Manager test mode before going live

# ── Phase 3: CareStack EHR (per-org, stored in connector_configs) ──
# All CareStack credentials live per-org in connector_configs.credentials:
#   account_id      — CareStack-AccountId (e.g. 10300)
#   client_id       — vendor's developer client_id
#   client_secret   — vendor's developer secret
#   username        — vendor key
#   password        — account key (per CareStack account)
#   webhook_secret  — base64 secret CareStack returns when registering the webhook
# Settings:
#   base_url        — defaults to https://api.carestack.com
#   identity_url    — defaults to https://id.carestack.com
# No global env vars required.

# ── Phase 3: Stripe (per-org via connector_configs OR env fallback for single-tenant) ──
# Per-org config (connector_configs.credentials):
#   secret_key       — sk_live_* or sk_test_*
#   webhook_secret   — whsec_* (verify incoming webhook signatures)
# Env fallback for single-tenant deploys:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_ORG_ID=  # uuid of the org to attribute env-fallback events to

# ── Phase 3: Windsor.ai (per-org via connector_configs) ──
# credentials.api_key — Windsor API key
# settings.data_sources — array, e.g. ['adwords','facebook']
# settings.account_ids — { adwords: '123-456-7890', facebook: 'act_123' } (optional)

# ── Phase 3: Brex (per-org via connector_configs) ──
# credentials.api_key  — Brex Personal Access Token
# settings.account_id  — optional account filter
